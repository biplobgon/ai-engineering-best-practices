# Development environment variables
# Copy to .env and fill in your API keys

# ============================================================================
# LLM API Keys
# ============================================================================

# Anthropic (default provider)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (fallback provider)
OPENAI_API_KEY=your_openai_key_here

# Other providers (optional)
BEDROCK_AWS_REGION=us-east-1
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Database & Cache
# ============================================================================

# Redis (caching, rate limiting)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (metadata + pgvector)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/aiengineer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aiengineer

# ============================================================================
# Service Configuration
# ============================================================================

# Default LLM model (cheap-first routing)
DEFAULT_LLM=anthropic/claude-3-5-haiku-20241022
FALLBACK_LLM=openai/gpt-4o-mini

# Cache settings
ENABLE_CACHE=true
CACHE_TTL=86400
SEMANTIC_CACHE_THRESHOLD=0.93

# ============================================================================
# Observability
# ============================================================================

# Jaeger (tracing)
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Application
# ============================================================================

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Environment
ENVIRONMENT=development

# ============================================================================
# Optional: LLMOps & Monitoring
# ============================================================================

# MLflow (model registry)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ai-engineering

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-engineering-best-practices

# Weights & Biases (optional)
WANDB_API_KEY=
WANDB_PROJECT=ai-engineering

# ============================================================================
# Optional: Deployment
# ============================================================================

# Celery (async jobs)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AWS (if deploying to AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
